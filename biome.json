{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!!.turbo",
      "!!coverage",
      "!!lib",
      "!!node_modules",
      "!!dist",
      "!!**/coverage",
      "!!**/dist",
      "!!**/lib",
      "!!**/node_modules"
    ]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "rules": {
      "recommended": false,
      "correctness": {
        "useExhaustiveDependencies": "warn"
      },
      "suspicious": {
        "noConsole": "off",
        "noExplicitAny": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "semicolons": "asNeeded",
      "bracketSpacing": true
    }
  },
  "css": {
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2
    }
  },
  "json": {
    "formatter": {
      "indentStyle": "space",
      "indentWidth": 2,
      "trailingCommas": "none"
    }
  }
}
