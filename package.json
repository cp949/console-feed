{
  "name": "console-feed-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "clean": "./clean.sh",
    "publish": "cd packages/console-feed && pnpm publish",
    "test:compat": "bash packages/console-feed/scripts/test-react-compat.sh both",
    "test:react18": "bash packages/console-feed/scripts/test-react-compat.sh 18",
    "test:react19": "bash packages/console-feed/scripts/test-react-compat.sh 19"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "turbo": "^2.9.6"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.24.0"
}
